# =============================================================================
# Sandcastle Agent 配置示例
# 复制为 .env 后按需修改，.env 已加入 .gitignore，不会提交到仓库。
# =============================================================================

# Planner（规划器）—— 深度依赖分析，推荐用 pro 模型
PLANNER_MODEL=deepseek-v4-pro
PLANNER_THINKING=high

# Implementer（实现器）—— 写代码，推荐用 flash 模型提效
IMPLEMENTER_MODEL=deepseek-v4-flash
IMPLEMENTER_THINKING=high

# Reviewer（审查器）—— 代码审查
REVIEWER_MODEL=deepseek-v4-flash
REVIEWER_THINKING=high

# Merger（合并器）—— 分支合并
MERGER_MODEL=deepseek-v4-flash
MERGER_THINKING=high

# thinking 可选值: off | minimal | low | medium | high | xhigh

# 阶段二 Implement Agent 并发上限（默认 5）
# 限制同时运行的 issue 实现流水线数量（每条 = implementer + reviewer），
# 防止过多 Agent 实例同时调用 LLM API 触发速率限制，或耗尽系统资源。
# MAX_CONCURRENT_ISSUES=5

# 无待处理工单时的休眠秒数（默认 60）
# 当 bd ready --json 返回空数组时，循环进入休眠而非空转消耗 token。
# IDLE_SLEEP_SECONDS=60
